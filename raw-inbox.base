filters:
  and:
    - file.inFolder("raw")
    - file.ext == "md"
formulas:
  age_days: (now() - file.ctime).days.round(0)
  has_source: if(source, "🔗 " + source, "— no URL")
properties:
  file.name:
    displayName: File
  formula.age_days:
    displayName: Days in inbox
  formula.has_source:
    displayName: Source URL
  file.ctime:
    displayName: Added
views:
  - type: table
    name: Unprocessed Raw Files
    order:
      - file.name
      - formula.has_source
      - formula.age_days
      - file.ctime
